DATABASE_URL="file:./razby.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Owner-code is the temporary production sign-in method while the app runs by IP.
RAZBY_OWNER_ACCESS_CODE="replace-with-long-random-owner-login-code"

# Email-code sign-in. Recommended before Google OAuth/domain is ready.
RAZBY_EMAIL_AUTH_ENABLED="false"
RAZBY_AUTH_EMAILS="owner@example.com"
RAZBY_EMAIL_FROM="Razby <no-reply@example.com>"
RAZBY_RESEND_API_KEY=""
RAZBY_EMAIL_CODE_TTL_MINUTES="10"
RAZBY_EMAIL_DEV_MODE="false"

# Google OAuth becomes the primary sign-in method after a domain is connected.
# Create credentials in Google Cloud Console and set these on VPS.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Local preview only. Set to "false" on VPS after owner-code or Google OAuth is configured.
RAZBY_DEMO_MODE="true"

# simulate keeps modules safe while the platform is being configured.
# live blocks runs until Telegram sessions, API keys, proxies and worker are ready.
RAZBY_EXECUTION_MODE="simulate"

# Optional. Used by process managers and Docker.
PORT="3000"
RAZBY_HOST_PORT="3000"
RAZBY_WORKER_ID="razby-worker-01"
RAZBY_ADMIN_TOKEN="replace-with-long-random-admin-bootstrap-token"
