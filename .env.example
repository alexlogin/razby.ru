# ─── Общие ───
NODE_ENV=development
COMPOSE_PROJECT_NAME=razby

# ─── PostgreSQL ───
POSTGRES_USER=razby
POSTGRES_PASSWORD=razby_dev_password
POSTGRES_DB=razby
DATABASE_URL=postgresql://razby:razby_dev_password@localhost:5432/razby?schema=public

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── API ───
PORT=4000
CORS_ORIGINS=http://localhost:3000

# JWT (ОБЯЗАТЕЛЬНО заменить в production на длинные случайные строки)
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Внешние сервисы (mock по умолчанию) ───
STORAGE_DRIVER=mock
STORAGE_PUBLIC_URL=http://localhost:4000/files
S3_ENDPOINT=
S3_REGION=ru-central1
S3_BUCKET=razby-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

SMS_DRIVER=mock
SMS_API_KEY=

EMAIL_DRIVER=mock
EMAIL_FROM=Razby.ru <no-reply@razby.ru>

PAYMENTS_DRIVER=mock
PAYMENTS_SECRET_KEY=

UPLOAD_MAX_MB=25
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf,video/mp4

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
