generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  name              String?
  email             String?         @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  passwordUpdatedAt DateTime?
  role              String          @default("OWNER")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  accounts          Account[]
  sessions          Session[]
  workspaces        Workspace[]
  referralCodes     ReferralCode[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id            String   @id @default(cuid())
  sessionToken  String   @unique
  userId        String
  expires       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier  String
  token       String   @unique
  expires     DateTime

  @@unique([identifier, token])
}

model Workspace {
  id                String             @id @default(cuid())
  name              String
  ownerId           String
  plan              String             @default("FOUNDATION")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner             User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  telegramAccounts  TelegramAccount[]
  proxies           ProxyEndpoint[]
  moduleRuns        ModuleRun[]
  leads             Lead[]
  campaigns         Campaign[]
  referralCodes     ReferralCode[]
  auditLogs         AuditLog[]
  integrations      IntegrationCredential[]
  settings          WorkspaceSetting[]
  workerHeartbeats  WorkerHeartbeat[]
  approvalItems     ApprovalItem[]
  conversations     TelegramConversation[]
  telegramAuthSessions TelegramAuthSession[]
}

model TelegramAccount {
  id           String         @id @default(cuid())
  workspaceId  String
  label        String
  username     String
  phone        String?
  status       String         @default("WARMING")
  healthScore  Int            @default(72)
  ggrScore     Float          @default(6.8)
  proxy        String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations TelegramConversation[]
}

model TelegramAuthSession {
  id             String     @id @default(cuid())
  workspaceId    String
  label          String
  phone          String
  status         String     @default("CODE_SENT")
  encryptedJson  String
  isCodeViaApp   Boolean    @default(false)
  expiresAt      DateTime
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, expiresAt])
}

model ProxyEndpoint {
  id             String       @id @default(cuid())
  workspaceId    String
  label          String
  protocol       String       @default("SOCKS5")
  host           String
  port           Int
  username       String?
  password       String?
  status         String       @default("UNKNOWN")
  latencyMs      Int?
  country        String?
  lastCheckedAt  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ModuleRun {
  id           String     @id @default(cuid())
  workspaceId  String
  moduleSlug   String
  title        String
  status       String     @default("QUEUED")
  inputJson    String
  resultJson   String?
  logsJson     String?
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  approvals    ApprovalItem[]

  @@index([workspaceId, moduleSlug, createdAt])
}

model ApprovalItem {
  id            String     @id @default(cuid())
  workspaceId   String
  moduleRunId   String?
  kind          String
  title         String
  status        String     @default("PENDING")
  risk          String     @default("medium")
  payloadJson   String
  decisionJson  String?
  createdAt     DateTime   @default(now())
  decidedAt     DateTime?
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  moduleRun     ModuleRun? @relation(fields: [moduleRunId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([moduleRunId])
}

model TelegramConversation {
  id                String             @id @default(cuid())
  workspaceId       String
  telegramAccountId String?
  peerUsername      String
  peerTitle         String
  source            String             @default("manual")
  status            String             @default("OPEN")
  priority          String             @default("NORMAL")
  tags              String             @default("[]")
  lastMessageAt     DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramAccount   TelegramAccount?   @relation(fields: [telegramAccountId], references: [id], onDelete: SetNull)
  messages          TelegramMessage[]

  @@index([workspaceId, status, lastMessageAt])
  @@index([telegramAccountId])
}

model TelegramMessage {
  id             String               @id @default(cuid())
  conversationId String
  direction      String
  authorUsername String?
  text           String
  aiDraft        String?
  status         String               @default("RECEIVED")
  createdAt      DateTime             @default(now())
  conversation   TelegramConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Lead {
  id           String     @id @default(cuid())
  workspaceId  String
  source       String
  username     String
  displayName  String
  bio          String?
  score        Int        @default(50)
  tags         String     @default("[]")
  createdAt    DateTime   @default(now())
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, source])
}

model Campaign {
  id            String          @id @default(cuid())
  workspaceId   String
  moduleSlug    String
  name          String
  status        String          @default("DRAFT")
  settingsJson  String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ReferralCode {
  id           String     @id @default(cuid())
  workspaceId  String
  ownerId      String
  code         String     @unique
  commission   Int        @default(20)
  clicks       Int        @default(0)
  signups      Int        @default(0)
  createdAt    DateTime   @default(now())
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            String     @id @default(cuid())
  workspaceId   String
  actorId       String?
  action        String
  entity        String
  entityId      String?
  metadataJson  String     @default("{}")
  createdAt     DateTime   @default(now())
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model IntegrationCredential {
  id             String     @id @default(cuid())
  workspaceId    String
  service        String
  label          String
  encryptedJson  String
  status         String     @default("NEEDS_CHECK")
  lastCheckedAt  DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, service, label])
  @@index([workspaceId, service])
}

model WorkerHeartbeat {
  id           String     @id @default(cuid())
  workspaceId  String
  workerId     String
  status       String     @default("ONLINE")
  metadataJson String     @default("{}")
  seenAt       DateTime   @default(now())
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, workerId])
  @@index([workspaceId, seenAt])
}

model WorkspaceSetting {
  id           String     @id @default(cuid())
  workspaceId  String
  key          String
  valueJson    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
}
