# ─── Production .env для razby.ru ───
# Скопируйте в .env на сервере: cp .env.production.example .env
# Затем заполните секреты (deploy.sh сгенерирует их автоматически, если оставить заглушки).

NODE_ENV=production

# Домен и e-mail для Let's Encrypt (HTTPS выпустится автоматически)
DOMAIN=razby.ru
ACME_EMAIL=admin@razby.ru

# PostgreSQL (порт наружу не публикуется)
POSTGRES_USER=razby
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=razby

# JWT — длинные случайные строки (openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET

# Внешние сервисы: mock работает без сторонних провайдеров.
# Для боевого режима поменяйте драйверы и добавьте ключи (см. docs/DEPLOYMENT.md).
STORAGE_DRIVER=mock
SMS_DRIVER=mock
EMAIL_DRIVER=mock
PAYMENTS_DRIVER=mock
