# ─── Production .env для razby.ru (приложение Razby) ───
# Скопируйте в .env на сервере: cp .env.production.example .env
# deploy.sh сгенерирует секреты автоматически, если оставить заглушки CHANGE_ME.

NODE_ENV=production

# Домен и e-mail для Let's Encrypt (HTTPS выпустится автоматически)
DOMAIN=razby.ru
ACME_EMAIL=admin@razby.ru

# NextAuth
NEXTAUTH_URL=https://razby.ru
NEXTAUTH_SECRET=CHANGE_ME

# База данных (SQLite-файл в томе appdata → /app/prisma)
DATABASE_URL=file:./razby.db

# Вход владельца по коду (пока сайт открывается без Google OAuth)
RAZBY_OWNER_ACCESS_CODE=CHANGE_ME
RAZBY_ADMIN_TOKEN=CHANGE_ME

# Email-вход одноразовым кодом (опционально, через Resend)
RAZBY_EMAIL_AUTH_ENABLED=false
RAZBY_AUTH_EMAILS=alexeyloginov90@gmail.com
RAZBY_EMAIL_FROM=Razby <no-reply@razby.ru>
RAZBY_RESEND_API_KEY=
RAZBY_EMAIL_CODE_TTL_MINUTES=10
RAZBY_EMAIL_DEV_MODE=false

# Google OAuth (подключается после настройки в Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Боевой режим: demo выключен, модули блокируются до готовности (simulate)
RAZBY_DEMO_MODE=false
RAZBY_EXECUTION_MODE=simulate

# Worker
RAZBY_WORKER_ID=vps-worker-01
