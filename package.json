{
  "name": "razby",
  "version": "1.0.0",
  "description": "Razby Telegram operations platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "check": "npm run db:generate && npm run build",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "node scripts/init-db.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "test": "tsx scripts/test-modules.ts",
    "worker": "tsx scripts/worker.ts",
    "worker:watch": "tsx scripts/worker.ts --watch"
  },
  "keywords": [
    "telegram",
    "saas",
    "automation",
    "razby"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "telegram": "^2.26.22",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
