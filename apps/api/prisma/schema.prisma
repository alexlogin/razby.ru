// Razby.ru — схема базы данных.
// PostgreSQL + Prisma ORM. Деньги хранятся в Decimal, гибкие поля — в Json.

generator client {
  provider      = "prisma-client-js"
  // native — для локали; musl-openssl-3.0 — для рантайма в Docker (node:20-alpine).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Перечисления (синхронизированы с packages/shared/src/enums.ts)
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  CONTRACTOR
  SUPPLIER
  CARRIER
  COORDINATOR
  ADMIN
  SUPERADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  PASSPORT
  INN
  OGRN
  LICENSE
  INSURANCE
  CERTIFICATE
  CONTRACT
  ACT
  PHOTO_REPORT
  OTHER
}

enum ProjectStatus {
  DRAFT
  CALCULATING
  ESTIMATED
  TENDERING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum StageStatus {
  BLOCKED
  PENDING
  SCHEDULED
  IN_PROGRESS
  REVIEW
  ACCEPTED
  REJECTED
  CANCELLED
}

enum WorkType {
  ANALYSIS
  SURVEY
  EARTHWORK
  LOGISTICS
  FOUNDATION
  INSTALLATION
  REINFORCEMENT
  FORMWORK
  CONCRETE
  BACKFILL
  ELECTRICAL
  VENTILATION
  LANDSCAPING
  ACCEPTANCE
}

enum QuestionType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTISELECT
  DATE
  ADDRESS
  MAP
  PHOTO
  VIDEO
  FILE
  DIMENSIONS
  VOLUME
  DISTANCE
}

enum OfferType {
  CONTRACTOR
  SUPPLIER
  CARRIER
}

enum OfferStatus {
  SUBMITTED
  SHORTLISTED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum TenderStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum NotificationType {
  SYSTEM
  PROJECT
  STAGE
  OFFER
  MESSAGE
  PAYMENT
  DELIVERY
  DISPUTE
}

enum Rounding {
  NONE
  UP
  DOWN
  NEAREST
}

// ─────────────────────────────────────────────────────────────────────────────
// Пользователи и доступ
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  passwordHash  String
  role          Role     @default(CUSTOMER)
  firstName     String?
  lastName      String?
  middleName    String?
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  phoneVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  isBlocked     Boolean  @default(false)
  tokenVersion  Int      @default(0)
  regionId      String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  region              Region?             @relation(fields: [regionId], references: [id])
  providerProfile     ProviderProfile?
  refreshTokens       RefreshToken[]
  verificationTokens  VerificationToken[]
  documents           Document[]
  projects            Project[]           @relation("CustomerProjects")
  managedProjects     Project[]           @relation("CoordinatorProjects")
  answers             ProjectAnswer[]     @relation("AnswerAuthor")
  offers              Offer[]
  reviewsAuthored     Review[]            @relation("ReviewAuthor")
  reviewsReceived     Review[]            @relation("ReviewTarget")
  messages            Message[]
  participations      ConversationParticipant[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  disputesOpened      Dispute[]           @relation("DisputeOpener")
  photoReports        PhotoReport[]
  payments            Payment[]
  formulaVersions     FormulaVersion[]    @relation("FormulaAuthor")
  promoRedemptions    PromoRedemption[]

  @@index([role])
  @@index([regionId])
}

/// Расширенный профиль исполнителя (подрядчик / поставщик / перевозчик).
model ProviderProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  companyName        String?
  inn                String?
  ogrn               String?
  description        String?
  workTypes          WorkType[]
  serviceRegionIds   String[]
  verificationStatus VerificationStatus @default(UNVERIFIED)
  ratingAvg          Decimal            @default(0) @db.Decimal(3, 2)
  reviewsCount       Int                @default(0)
  completedOrders    Int                @default(0)
  cancelledOrders    Int                @default(0)
  onTimeRate         Decimal            @default(1) @db.Decimal(3, 2) // 0..1
  warrantyMonths     Int                @default(0)
  baseLat            Float?
  baseLng            Float?
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  family    String // семейство для ротации
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  channel   String // "EMAIL" | "PHONE"
  codeHash  String
  target    String // email или телефон
  attempts  Int      @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
}

model Document {
  id           String             @id @default(cuid())
  ownerId      String
  type         DocumentType
  title        String
  storageKey   String // ключ в S3-совместимом хранилище
  mimeType     String
  sizeBytes    Int
  status       VerificationStatus @default(PENDING)
  reviewNote   String?
  projectId    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([projectId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Справочники
// ─────────────────────────────────────────────────────────────────────────────

model Region {
  id           String   @id @default(cuid())
  code         String   @unique // напр. RU-MOW
  name         String
  timezone     String   @default("Europe/Moscow")
  priceFactor  Decimal  @default(1) @db.Decimal(6, 3) // региональный коэффициент цен
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  users          User[]
  regionalPrices RegionalPrice[]
  projects       Project[]
}

model MaterialCategory {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  parentId  String?
  parent    MaterialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  MaterialCategory[] @relation("CategoryTree")
  materials Material[]
}

model Material {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  unit        String // м3, кг, шт, м.п. ...
  categoryId  String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category             MaterialCategory      @relation(fields: [categoryId], references: [id])
  regionalPrices       RegionalPrice[]
  stageTemplateLinks   StageTemplateMaterial[]
  projectStageMaterials ProjectStageMaterial[]

  @@index([categoryId])
}

/// Цена материала в регионе с периодом действия (история цен).
model RegionalPrice {
  id         String   @id @default(cuid())
  materialId String
  regionId   String
  price      Decimal  @db.Decimal(14, 2)
  currency   String   @default("RUB")
  validFrom  DateTime @default(now())
  validTo    DateTime?
  source     String? // прайс/поставщик
  createdAt  DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([materialId, regionId, validFrom])
}

model Specialist {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String // напр. "Экскаваторщик"
  description String?
  workType    WorkType
  dayRateHint Decimal? @db.Decimal(14, 2) // ориентир, не для расчёта сметы
  createdAt   DateTime @default(now())

  stageTemplateLinks StageTemplateSpecialist[]
}

model Equipment {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String // напр. "Экскаватор-погрузчик"
  description String?
  unit        String   @default("смена")
  rateHint    Decimal? @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  stageTemplateLinks StageTemplateEquipment[]
}

model Risk {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  severity    Int      @default(1) // 1..5
  mitigation  String?
  createdAt   DateTime @default(now())

  stageTemplateLinks StageTemplateRisk[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Движок расчётов: формулы и версии
// ─────────────────────────────────────────────────────────────────────────────

/// Формула расчёта. Стабильные метаданные тут, изменяемая часть — в версиях.
/// Числа считаются ТОЛЬКО формулами, ИИ их не выдумывает.
model Formula {
  id          String   @id @default(cuid())
  key         String   @unique // напр. "excavation_volume"
  name        String
  description String?
  unit        String // единица результата
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions           FormulaVersion[]
  stageMaterialLinks StageTemplateMaterial[]
}

model FormulaVersion {
  id             String   @id @default(cuid())
  formulaId      String
  version        Int
  expression     String // выражение, напр. "length*width*depth"
  variables      Json // [{ key, label, unit, source }]
  minValue       Decimal? @db.Decimal(18, 4)
  maxValue       Decimal? @db.Decimal(18, 4)
  rounding       Rounding @default(NEAREST)
  roundingStep   Decimal  @default(1) @db.Decimal(18, 4)
  safetyFactor   Decimal  @default(1) @db.Decimal(8, 4) // коэффициент запаса
  regionFactorOn Boolean  @default(false) // применять региональный коэффициент
  validFrom      DateTime @default(now())
  validTo        DateTime?
  authorId       String?
  changeNote     String?
  createdAt      DateTime @default(now())

  formula Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  author  User?   @relation("FormulaAuthor", fields: [authorId], references: [id])

  @@unique([formulaId, version])
  @@index([formulaId, validFrom])
}

// ─────────────────────────────────────────────────────────────────────────────
// Шаблоны проектов, анкеты, шаблоны этапов
// ─────────────────────────────────────────────────────────────────────────────

model ProjectTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  workType    WorkType
  coverUrl    String?
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questionnaire  Questionnaire?
  stageTemplates StageTemplate[]
  projects       Project[]
}

model Questionnaire {
  id          String   @id @default(cuid())
  templateId  String   @unique
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template  ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions Question[]
}

model Question {
  id              String       @id @default(cuid())
  questionnaireId String
  code            String // уникальный ключ ответа внутри анкеты
  label           String
  hint            String?
  type            QuestionType
  required        Boolean      @default(false)
  order           Int          @default(0)
  // условный показ: { questionCode, op, value }
  conditionalOn   Json?
  // привязка ответа к переменной формулы (variableKey используется в выражениях)
  variableKey     String?
  // привязки к этапу/риску по коду
  linkedStageCode String?
  linkedRiskCode  String?
  validation      Json? // { min, max, regex, ... }
  unit            String?
  createdAt       DateTime     @default(now())

  questionnaire Questionnaire    @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  options       QuestionOption[]

  @@unique([questionnaireId, code])
  @@index([questionnaireId, order])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  value      String
  label      String
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model StageTemplate {
  id                 String   @id @default(cuid())
  templateId         String
  code               String // уникальный код этапа внутри шаблона
  order              Int
  name               String
  description        String
  workType           WorkType
  estimatedDays      Decimal  @default(1) @db.Decimal(6, 2)
  photoRequirements  Json     @default("[]") // [{ code, label, min }]
  checklist          Json     @default("[]") // [{ code, label, required }]
  acceptanceCriteria Json     @default("[]") // [string]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  template     ProjectTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  materials    StageTemplateMaterial[]
  specialists  StageTemplateSpecialist[]
  equipment    StageTemplateEquipment[]
  risks        StageTemplateRisk[]
  dependsOn    StageTemplateDependency[] @relation("StageDependent")
  requiredBy   StageTemplateDependency[] @relation("StageRequirement")
  projectStages ProjectStage[]

  @@unique([templateId, code])
  @@index([templateId, order])
}

/// Зависимость между шаблонными этапами (этап X нельзя начать до этапа Y).
model StageTemplateDependency {
  id           String  @id @default(cuid())
  stageId      String // зависимый этап
  requiresId   String // требуемый этап
  type         String  @default("FINISH_TO_START")

  stage    StageTemplate @relation("StageDependent", fields: [stageId], references: [id], onDelete: Cascade)
  requires StageTemplate @relation("StageRequirement", fields: [requiresId], references: [id], onDelete: Cascade)

  @@unique([stageId, requiresId])
}

model StageTemplateMaterial {
  id            String  @id @default(cuid())
  stageId       String
  materialId    String
  // формула расчёта количества материала на этом этапе
  quantityFormulaId String?
  fixedQuantity Decimal? @db.Decimal(18, 4)
  note          String?

  stage           StageTemplate @relation(fields: [stageId], references: [id], onDelete: Cascade)
  material        Material      @relation(fields: [materialId], references: [id])
  quantityFormula Formula?      @relation(fields: [quantityFormulaId], references: [id])

  @@unique([stageId, materialId])
}

model StageTemplateSpecialist {
  id           String @id @default(cuid())
  stageId      String
  specialistId String
  count        Int    @default(1)

  stage      StageTemplate @relation(fields: [stageId], references: [id], onDelete: Cascade)
  specialist Specialist    @relation(fields: [specialistId], references: [id])

  @@unique([stageId, specialistId])
}

model StageTemplateEquipment {
  id          String @id @default(cuid())
  stageId     String
  equipmentId String
  count       Int    @default(1)

  stage     StageTemplate @relation(fields: [stageId], references: [id], onDelete: Cascade)
  equipment Equipment     @relation(fields: [equipmentId], references: [id])

  @@unique([stageId, equipmentId])
}

model StageTemplateRisk {
  id      String @id @default(cuid())
  stageId String
  riskId  String

  stage StageTemplate @relation(fields: [stageId], references: [id], onDelete: Cascade)
  risk  Risk          @relation(fields: [riskId], references: [id])

  @@unique([stageId, riskId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Проекты
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id             String        @id @default(cuid())
  number         Int           @unique @default(autoincrement())
  customerId     String
  coordinatorId  String?
  templateId     String?
  regionId       String?
  title          String
  status         ProjectStatus @default(DRAFT)
  address        String?
  lat            Float?
  lng            Float?
  startDate      DateTime?
  targetEndDate  DateTime?
  progress       Int           @default(0) // 0..100
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer    User             @relation("CustomerProjects", fields: [customerId], references: [id])
  coordinator User?            @relation("CoordinatorProjects", fields: [coordinatorId], references: [id])
  template    ProjectTemplate? @relation(fields: [templateId], references: [id])
  region      Region?          @relation(fields: [regionId], references: [id])

  answers       ProjectAnswer[]
  stages        ProjectStage[]
  estimates     Estimate[]
  tenders       Tender[]
  offers        Offer[]
  deliveries    Delivery[]
  payments      Payment[]
  documents     Document[]
  conversations Conversation[]
  notifications Notification[]
  photoReports  PhotoReport[]
  disputes      Dispute[]
  reviews       Review[]
  promoRedemptions PromoRedemption[]

  @@index([customerId])
  @@index([status])
  @@index([regionId])
}

model ProjectAnswer {
  id         String   @id @default(cuid())
  projectId  String
  questionCode String
  value      Json // нормализованное значение ответа
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?   @relation("AnswerAuthor", fields: [authorId], references: [id])

  @@unique([projectId, questionCode])
}

model ProjectStage {
  id              String      @id @default(cuid())
  projectId       String
  stageTemplateId String?
  code            String
  order           Int
  name            String
  description     String
  workType        WorkType
  status          StageStatus @default(BLOCKED)
  estimatedDays   Decimal     @default(1) @db.Decimal(6, 2)
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  assigneeId      String? // выбранный исполнитель (User провайдера)
  estimatedCost   Decimal     @default(0) @db.Decimal(14, 2)
  actualCost      Decimal     @default(0) @db.Decimal(14, 2)
  checklistState  Json        @default("[]") // [{ code, done, doneAt }]
  acceptedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageTemplate StageTemplate?       @relation(fields: [stageTemplateId], references: [id])
  materials     ProjectStageMaterial[]
  dependsOn     ProjectStageDependency[] @relation("PStageDependent")
  requiredBy    ProjectStageDependency[] @relation("PStageRequirement")
  tenders       Tender[]
  offers        Offer[]
  deliveries    Delivery[]
  photoReports  PhotoReport[]
  acceptanceAct AcceptanceAct?

  @@unique([projectId, code])
  @@index([projectId, order])
  @@index([status])
}

model ProjectStageDependency {
  id         String @id @default(cuid())
  stageId    String
  requiresId String
  type       String @default("FINISH_TO_START")

  stage    ProjectStage @relation("PStageDependent", fields: [stageId], references: [id], onDelete: Cascade)
  requires ProjectStage @relation("PStageRequirement", fields: [requiresId], references: [id], onDelete: Cascade)

  @@unique([stageId, requiresId])
}

model ProjectStageMaterial {
  id              String   @id @default(cuid())
  stageId         String
  materialId      String
  quantity        Decimal  @db.Decimal(18, 4)
  unit            String
  unitPrice       Decimal  @default(0) @db.Decimal(14, 2) // зафиксированная региональная цена
  totalPrice      Decimal  @default(0) @db.Decimal(14, 2)
  formulaKey      String?
  formulaVersion  Int?
  calcTrace       Json? // { inputs, raw, afterSafety, afterRegion, final }
  ordered         Boolean  @default(false)
  createdAt       DateTime @default(now())

  stage    ProjectStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  material Material     @relation(fields: [materialId], references: [id])

  @@unique([stageId, materialId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Смета и её история
// ─────────────────────────────────────────────────────────────────────────────

model Estimate {
  id            String   @id @default(cuid())
  projectId     String
  version       Int      @default(1)
  isCurrent     Boolean  @default(true)
  materialsCost Decimal  @default(0) @db.Decimal(14, 2)
  worksCost     Decimal  @default(0) @db.Decimal(14, 2)
  logisticsCost Decimal  @default(0) @db.Decimal(14, 2)
  commission    Decimal  @default(0) @db.Decimal(14, 2)
  discount      Decimal  @default(0) @db.Decimal(14, 2)
  total         Decimal  @default(0) @db.Decimal(14, 2)
  turnkeyTotal  Decimal  @default(0) @db.Decimal(14, 2) // оценка "под ключ" для сравнения экономии
  currency      String   @default("RUB")
  note          String?
  createdById   String?
  createdAt     DateTime @default(now())

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   EstimateItem[]

  @@unique([projectId, version])
  @@index([projectId])
}

model EstimateItem {
  id         String   @id @default(cuid())
  estimateId String
  stageCode  String?
  kind       String // "MATERIAL" | "WORK" | "LOGISTICS" | "COMMISSION" | "DISCOUNT"
  title      String
  unit       String?
  quantity   Decimal  @default(1) @db.Decimal(18, 4)
  unitPrice  Decimal  @default(0) @db.Decimal(14, 2)
  total      Decimal  @default(0) @db.Decimal(14, 2)
  meta       Json?

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Тендеры и предложения
// ─────────────────────────────────────────────────────────────────────────────

model Tender {
  id          String       @id @default(cuid())
  projectId   String
  stageId     String?
  type        OfferType
  title       String
  description String?
  status      TenderStatus @default(OPEN)
  spec        Json         @default("{}") // структурированная заявка (объёмы, материалы)
  deadline    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage   ProjectStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  offers  Offer[]

  @@index([projectId])
  @@index([status])
}

model Offer {
  id          String      @id @default(cuid())
  tenderId    String
  projectId   String
  stageId     String?
  providerId  String // User провайдера
  type        OfferType
  status      OfferStatus @default(SUBMITTED)
  price       Decimal     @db.Decimal(14, 2)
  // общие
  availableDate DateTime?
  durationDays  Decimal?  @db.Decimal(6, 2)
  warrantyMonths Int      @default(0)
  comment       String?
  validUntil    DateTime?
  // подрядчик
  workersCount  Int?
  includes      String[]
  excludes      String[]
  // поставщик
  unitPrice     Decimal?  @db.Decimal(14, 2)
  minOrder      Decimal?  @db.Decimal(18, 4)
  inStock       Boolean?
  deliveryDate  DateTime?
  deliveryCost  Decimal?  @db.Decimal(14, 2)
  unloading     Boolean?
  // перевозчик
  vehicleType   String?
  capacityTons  Decimal?  @db.Decimal(10, 3)
  dimensions    String?
  calloutCost   Decimal?  @db.Decimal(14, 2)
  pricePerKm    Decimal?  @db.Decimal(14, 2)
  // расчётное
  score         Decimal?  @db.Decimal(6, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tender   Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage    ProjectStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  provider User          @relation(fields: [providerId], references: [id])

  @@index([tenderId])
  @@index([providerId])
  @@index([status])
}

model Delivery {
  id          String   @id @default(cuid())
  projectId   String
  stageId     String?
  carrierId   String?
  title       String
  fromAddress String?
  toAddress   String?
  distanceKm  Decimal? @db.Decimal(10, 2)
  weightTons  Decimal? @db.Decimal(10, 3)
  cost        Decimal  @default(0) @db.Decimal(14, 2)
  scheduledAt DateTime?
  deliveredAt DateTime?
  status      String   @default("PLANNED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage   ProjectStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Платежи, комиссии, промокоды
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  projectId   String
  payerId     String
  stageCode   String?
  amount      Decimal       @db.Decimal(14, 2)
  commission  Decimal       @default(0) @db.Decimal(14, 2)
  currency    String        @default("RUB")
  status      PaymentStatus @default(PENDING)
  provider    String        @default("mock")
  externalId  String?
  description String?
  heldAt      DateTime?
  releasedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payer   User    @relation(fields: [payerId], references: [id])

  @@index([projectId])
  @@index([status])
}

model CommissionRule {
  id         String   @id @default(cuid())
  name       String
  workType   WorkType?
  percent    Decimal  @db.Decimal(5, 2)
  minAmount  Decimal  @default(0) @db.Decimal(14, 2)
  isActive   Boolean  @default(true)
  validFrom  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  percentOff    Decimal? @db.Decimal(5, 2)
  amountOff     Decimal? @db.Decimal(14, 2)
  maxRedemptions Int?
  usedCount     Int      @default(0)
  validFrom     DateTime @default(now())
  validTo       DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  projectId   String?
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([promoCodeId, userId, projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Коммуникации, приёмка, отзывы, споры
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  projectId String?
  topic     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([projectId])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  attachments    Json     @default("[]")
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model PhotoReport {
  id          String   @id @default(cuid())
  projectId   String
  stageId     String?
  authorId    String
  title       String?
  photos      Json     @default("[]") // [{ storageKey, takenAt, lat, lng }]
  comment     String?
  createdAt   DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage   ProjectStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  author  User          @relation(fields: [authorId], references: [id])

  @@index([projectId])
}

/// Акт приёмки этапа.
model AcceptanceAct {
  id         String   @id @default(cuid())
  stageId    String   @unique
  number     String
  acceptedById String
  amount     Decimal  @default(0) @db.Decimal(14, 2)
  note       String?
  signedAt   DateTime @default(now())
  storageKey String? // PDF акта

  stage ProjectStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  projectId  String
  authorId   String
  targetId   String
  rating     Int // 1..5
  text       String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  target  User    @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([projectId, authorId, targetId])
  @@index([targetId])
}

model Dispute {
  id          String        @id @default(cuid())
  projectId   String
  openedById  String
  stageCode   String?
  subject     String
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  openedBy User    @relation("DisputeOpener", fields: [openedById], references: [id])

  @@index([projectId])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  projectId String?
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  data      Json             @default("{}")
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Аудит и системные настройки
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
